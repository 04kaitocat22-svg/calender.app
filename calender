<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>タスク管理カレンダー</title>
    <style>
        body { font-family: sans-serif; padding: 20px; background: #f4f4f9; display: flex; flex-direction: column; align-items: center; }
        .calendar, .editor { background: white; width: 100%; max-width: 400px; padding: 15px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 20px; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; }
        td { text-align: center; padding: 10px 0; cursor: pointer; }
        .today { border: 2px solid #ff5722; color: #ff5722; font-weight: bold; border-radius: 50%; }
        .selected { background-color: rgba(0, 150, 255, 0.3); border-radius: 50%; }
        
        #chart-container { position: relative; width: 200px; height: 200px; margin: 40px auto; border-radius: 50%; border: 2px solid #ddd; }
        #chart { width: 100%; height: 100%; border-radius: 50%; position: relative; overflow: hidden; }
        
        .segment { position: absolute; width: 100%; height: 100%; animation: sweep 2s ease-out forwards; }
        @keyframes sweep { from { clip-path: polygon(50% 50%, 50% 0%, 50% 0%, 50% 0%); } to { clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%, 50% 0%); } }
        
        .time-label { position: absolute; font-size: 10px; color: #555; }
        #eventList { margin-top: 15px; font-size: 0.9em; }
        .delete-check { margin-right: 10px; }
    </style>
</head>
<body>

<div id="todayDisplay" style="margin-bottom: 10px; font-weight: bold;"></div>
<div class="calendar">
    <div class="header">
        <button onclick="changeMonth(-1)">＜</button>
        <div><span id="monthYear"></span> <button onclick="jumpToToday()">今日へ</button></div>
        <button onclick="changeMonth(1)">＞</button>
    </div>
    <table id="calendarTable"></table>
</div>

<div class="editor">
    <h3 id="selectedDateText">日付を選択してください</h3>
    <div id="chart-container"><div id="chart"></div></div>
    <div id="eventList"></div>
    <button id="modeBtn" onclick="toggleDeleteMode()">削除モードにする</button>
    <button id="deleteBtn" style="display:none;" onclick="confirmDelete()">選択した予定を削除</button>
    <hr>
    <input type="time" id="start"> ～ <input type="time" id="end"><br>
    <input type="text" id="title" placeholder="予定名">
    <input type="color" id="color" value="#ff5722">
    <button onclick="addEvent()">追加</button>
</div>

<script>
    // ★ここをスプレッドシートのURLに書き換えてください★
    const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwVnq8HN2V4Dtmg0pLy9Yo69_bofBV_U7duiUZUshTRMH4ZU0AiHVy3L6mfO2xB5Mru/exec';

    let currentDate = new Date();
    let events = {}; // クラウドから取得したデータを格納
    let selectedDate = "";
    let isDeleteMode = false;

    // データ読み込み
    async function fetchData() {
        const response = await fetch(SCRIPT_URL);
        const data = await response.json();
        events = {};
        // 2行目から読み込み (1行目はヘッダー)
        data.slice(1).forEach(row => {
            const [date, start, end, title, color] = row;
            if(!events[date]) events[date] = [];
            events[date].push({start, end, title, color});
        });
        renderCalendar();
        if(selectedDate) updateChart();
    }

    function renderCalendar() {
        const year = currentDate.getFullYear();
        const month = currentDate.getMonth();
        const now = new Date();
        document.getElementById('monthYear').innerText = `${year}年 ${month + 1}月`;
        document.getElementById('todayDisplay').innerText = `本日は ${now.getFullYear()}年${now.getMonth()+1}月${now.getDate()}日です`;
        
        let html = '<tr><th>日</th><th>月</th><th>火</th><th>水</th><th>木</th><th>金</th><th>土</th></tr><tr>';
        const firstDay = new Date(year, month, 1).getDay();
        const lastDate = new Date(year, month + 1, 0).getDate();
        
        for(let i=0; i<firstDay; i++) html += '<td></td>';
        for(let d=1; d<=lastDate; d++) {
            if((firstDay + d - 1) % 7 === 0) html += '</tr><tr>';
            const isToday = (year === now.getFullYear() && month === now.getMonth() && d === now.getDate());
            const isSelected = (selectedDate === `${year}-${month}-${d}`);
            html += `<td class="${isToday ? 'today' : ''} ${isSelected ? 'selected' : ''}" onclick="selectDate(${year}, ${month}, ${d})">${d}</td>`;
        }
        document.getElementById('calendarTable').innerHTML = html + '</tr>';
    }

    async function addEvent() {
        if(!selectedDate) return alert("日付を選択してください");
        const start = document.getElementById('start').value;
        const end = document.getElementById('end').value;
        const title = document.getElementById('title').value;
        const color = document.getElementById('color').value;
        if(!start || !end || !title) return alert("全て入力してください");
        
        const sMin = start.split(':').reduce((a,b) => a*60 + parseInt(b), 0);
        const eMin = end.split(':').reduce((a,b) => a*60 + parseInt(b), 0);
        if(eMin <= sMin) return alert("終了時間は開始時間より後に設定してください！");
        
        // データ送信
        await fetch(SCRIPT_URL, {
            method: 'POST',
            body: JSON.stringify({type: 'add', date: selectedDate, start, end, title, color})
        });
        
        await fetchData(); // 再取得して更新
    }

    function updateChart() {
        const chart = document.getElementById('chart');
        const list = document.getElementById('eventList');
        chart.innerHTML = "";
        list.innerHTML = "";
        
        const dayEvents = (events[selectedDate] || []).sort((a,b) => a.start.localeCompare(b.start));
        dayEvents.forEach((e, index) => {
            const s = e.start.split(':').reduce((a,b) => a*60 + parseInt(b), 0);
            const len = (e.end.split(':').reduce((a,b) => a*60 + parseInt(b), 0) - s) / 1440 * 360;
            const deg = (s / 1440 * 360);
            
            const div = document.createElement('div');
            div.className = 'segment';
            div.style.background = `conic-gradient(${e.color} ${len}deg, transparent 0deg)`;
            div.style.transform = `rotate(${deg}deg)`;
            chart.appendChild(div);
            
            const check = isDeleteMode ? `<input type="checkbox" class="delete-check" value="${index}"> ` : "";
            list.innerHTML += `<div>${check}${e.start}~${e.end} : ${e.title}</div>`;
        });
    }

    function toggleDeleteMode() {
        isDeleteMode = !isDeleteMode;
        document.getElementById('modeBtn').innerText = isDeleteMode ? "通常モードに戻す" : "削除モードにする";
        document.getElementById('deleteBtn').style.display = isDeleteMode ? "inline" : "none";
        updateChart();
    }

    // 注意：削除処理はスプレッドシート側のコード修正も必要になります（今回は読み込み優先で設計）
    function confirmDelete() { alert("削除機能はデータベース連携中のため、シートから直接削除してください。"); }

    function selectDate(y, m, d) {
        selectedDate = `${y}-${m}-${d}`;
        document.getElementById('selectedDateText').innerText = `${m+1}月${d}日の予定一覧`;
        renderCalendar();
        updateChart();
    }
    
    function drawTimeLabels() {
        const container = document.getElementById('chart-container');
        for(let i=0; i<12; i++) {
            const label = document.createElement('div');
            label.className = 'time-label';
            label.innerText = i * 2;
            const angle = (i * 30 - 90) * (Math.PI / 180);
            label.style.left = (100 + 120 * Math.cos(angle) - 5) + 'px';
            label.style.top = (100 + 120 * Math.sin(angle) - 5) + 'px';
            container.appendChild(label);
        }
    }

    function changeMonth(delta) { currentDate.setMonth(currentDate.getMonth() + delta); renderCalendar(); }
    function jumpToToday() { currentDate = new Date(); renderCalendar(); }

    fetchData(); // 初回データ取得
    drawTimeLabels();
</script>
</body>
</html>
